# ============================================================
# Jidou Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# -----------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------
POSTGRES_USER=jidou
POSTGRES_PASSWORD=jidou_dev_password
POSTGRES_DB=jidou
POSTGRES_PORT=5432

# Database connection URL (used by API and worker containers)
DATABASE_URL=postgresql+asyncpg://jidou:jidou_dev_password@postgres:5432/jidou

# -----------------------------------------------------------
# Redis (broker + cache + rate limiter)
# -----------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------
# API Server
# -----------------------------------------------------------
API_PORT=8192
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3100

# -----------------------------------------------------------
# Frontend
# -----------------------------------------------------------
FRONTEND_PORT=3100

# -----------------------------------------------------------
# TMDB API
# -----------------------------------------------------------
# Get your API key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3

# TMDB rate limiting (default: 1 call per 2 seconds)
TMDB_RATE_LIMIT_PER_SECOND=0.5

# TMDB response cache TTL (in seconds)
TMDB_CACHE_TTL_SHOWS=86400
TMDB_CACHE_TTL_SEARCH=3600

# -----------------------------------------------------------
# SFTP (remote file server — required for scan and download tasks)
# -----------------------------------------------------------
SFTP_HOST=sftp.example.com
SFTP_PORT=22
SFTP_USERNAME=your_sftp_username
# Use either password or key-based auth, not both
SFTP_PASSWORD=
SFTP_KEY_PATH=
# Comma-separated list of remote paths to scan for new files
SFTP_REMOTE_PATHS=/downloads,/completed
# Parallel download workers (1-32, default 8)
SFTP_MAX_WORKERS=8
# Retry attempts on transient connection failures (0 = no retry, default 3)
SFTP_MAX_RETRIES=3
# Initial backoff between retries in seconds; doubles each attempt (default 1.0)
SFTP_RETRY_DELAY=1.0

# Local directory used as a staging area for downloaded files
# Files land here after download and are moved to their final show path after matching
LOCAL_STAGING_PATH=/data/staging

# Base paths for routed media (used to suggest local_path when resolving unmatched files)
LOCAL_TV_PATH=/data/media/tv
LOCAL_ANIME_PATH=/data/media/anime
LOCAL_MOVIE_PATH=/data/media/movies

# -----------------------------------------------------------
# LLM (optional - falls back to heuristic matching if unavailable)
# -----------------------------------------------------------
# Supported providers: openai, anthropic, ollama, lmstudio, none
LLM_PROVIDER=none
# API key (required for openai and anthropic; leave blank for ollama/lmstudio)
LLM_API_KEY=
# Override the provider's default base URL (useful for self-hosted instances)
# openai default: https://api.openai.com
# anthropic default: https://api.anthropic.com
# ollama default: http://localhost:11434
# lmstudio default: http://localhost:1234
LLM_BASE_URL=
# Model identifier (required when LLM_PROVIDER is not 'none')
# Examples: gpt-4o-mini, claude-3-haiku-20240307, llama3, mistral
LLM_MODEL=
# Response cache TTL in seconds (default 3600)
LLM_CACHE_TTL=3600
# HTTP timeout per LLM call in seconds (default 30)
LLM_TIMEOUT=30

# -----------------------------------------------------------
# Celery
# -----------------------------------------------------------
CELERY_CONCURRENCY=4
CELERY_PREFETCH_MULTIPLIER=1
