# ============================================================
# Jidou Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# -----------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------
POSTGRES_USER=jidou
POSTGRES_PASSWORD=jidou_dev_password
POSTGRES_DB=jidou
POSTGRES_PORT=5432

# Database connection URL (used by API and worker containers)
DATABASE_URL=postgresql+asyncpg://jidou:jidou_dev_password@postgres:5432/jidou

# -----------------------------------------------------------
# Redis (broker + cache + rate limiter)
# -----------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------
# API Server
# -----------------------------------------------------------
API_PORT=8192
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3100

# Static API key for all /api routes.
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
# Leave unset or empty to disable auth (safe for isolated local development).
JIDOU_API_KEY=

# -----------------------------------------------------------
# Frontend
# -----------------------------------------------------------
FRONTEND_PORT=3100

# -----------------------------------------------------------
# TMDB API
# -----------------------------------------------------------
# Get your API key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3

# TMDB rate limiting (calls per second; range 0.1–2.0, default 0.5)
TMDB_RATE_LIMIT_PER_SECOND=0.5

# TMDB response cache TTL in seconds (default 86400 = 24 hours)
TMDB_CACHE_TTL=86400

# -----------------------------------------------------------
# SFTP (remote file server — required for scan and download tasks)
# -----------------------------------------------------------
SFTP_HOST=sftp.example.com
SFTP_PORT=22
SFTP_USERNAME=your_sftp_username
# Use either password or key-based auth, not both
SFTP_PASSWORD=
# Key-based auth: set SFTP_KEY_FILE to the host path of your SSH private key.
# The compose file mounts it read-only into the container at /run/secrets/sftp_key.
# Then set SFTP_KEY_PATH to the container path so the app can find it.
#
# Example:
#   SFTP_KEY_FILE=C:/Users/james/.ssh/id_rsa   (host path — used by Docker)
#   SFTP_KEY_PATH=/run/secrets/sftp_key         (container path — used by the app)
SFTP_KEY_FILE=
SFTP_KEY_PATH=
# Comma-separated list of remote paths to scan for new files
SFTP_REMOTE_PATHS=/downloads,/completed
# Parallel download workers (1-32, default 8)
SFTP_MAX_WORKERS=8
# Retry attempts on transient connection failures (0 = no retry, default 3)
SFTP_MAX_RETRIES=3
# Initial backoff between retries in seconds; doubles each attempt (default 1.0)
SFTP_RETRY_DELAY=1.0

# Media path configuration — two variables per path:
#
#   LOCAL_*_HOST_PATH — source on the Docker host (used only in docker-compose.yml
#                       volume mount, host side).  Windows paths with drive letters
#                       are valid here (e.g. D:\media\staging).
#   LOCAL_*_PATH      — path inside the container used by the Python application.
#                       Must be a Linux/POSIX path.
#
# On Linux/macOS the two values can be the same POSIX path.
# On Windows Docker Desktop they must differ — the host path uses a drive letter
# while the container path is always Linux.
#
# Windows Docker Desktop example:
#   LOCAL_STAGING_HOST_PATH=D:\Documents\Code\Jidou\downloads\staging
#   LOCAL_STAGING_PATH=/data/staging
#
# Linux/macOS example (same path for both):
#   LOCAL_STAGING_HOST_PATH=/mnt/nas/staging
#   LOCAL_STAGING_PATH=/mnt/nas/staging

# Staging area for downloaded files (moved to media paths after matching)
LOCAL_STAGING_HOST_PATH=/data/staging
LOCAL_STAGING_PATH=/data/staging

# Base paths for routed media (RouteOrchestrator moves MATCHED files here)
LOCAL_TV_HOST_PATH=/data/media/tv
LOCAL_TV_PATH=/data/media/tv
LOCAL_ANIME_HOST_PATH=/data/media/anime
LOCAL_ANIME_PATH=/data/media/anime
LOCAL_MOVIE_HOST_PATH=/data/media/movies
LOCAL_MOVIE_PATH=/data/media/movies

# -----------------------------------------------------------
# LLM (optional - falls back to heuristic matching if unavailable)
# -----------------------------------------------------------
# Supported providers: openai, anthropic, ollama, lmstudio, none
LLM_PROVIDER=none
# API key (required for openai and anthropic; leave blank for ollama/lmstudio)
LLM_API_KEY=
# Override the provider's default base URL (useful for self-hosted instances)
# openai default: https://api.openai.com
# anthropic default: https://api.anthropic.com
# ollama default: http://localhost:11434
# lmstudio default: http://localhost:1234
LLM_BASE_URL=
# Model identifier (required when LLM_PROVIDER is not 'none')
# Examples: gpt-4o-mini, claude-3-haiku-20240307, llama3, mistral
LLM_MODEL=
# Response cache TTL in seconds (default 3600)
LLM_CACHE_TTL=3600
# HTTP timeout per LLM call in seconds (default 30)
LLM_TIMEOUT=30
# Prepend /no_think to the user message for Qwen3 and similar reasoning models
# that ignore system-prompt instructions to skip chain-of-thought.
# Safe to leave on for other model families - it is a no-op if unrecognised.
# Default: true
LLM_NO_THINK=true

# -----------------------------------------------------------
# Celery worker
# -----------------------------------------------------------
# Number of concurrent worker processes (default 4)
CELERY_CONCURRENCY=4
# Tasks prefetched per worker (default 1 — keep at 1 for long-running tasks)
CELERY_PREFETCH_MULTIPLIER=1

# -----------------------------------------------------------
# Scheduled tasks (Celery beat — requires jidou-beat service)
# -----------------------------------------------------------
# Enable automatic full sync on a daily crontab schedule.
# Set SYNC_SCHEDULE_HOURS to a comma-separated list of UTC hours to fire
# (e.g. "2" = 02:00 UTC daily, "2,14" = 02:00 and 14:00 UTC daily).
# Restart the jidou-beat container to apply changes.
SYNC_SCHEDULE_ENABLED=false
SYNC_SCHEDULE_HOURS=2

# Enable automatic RSS import on a daily crontab schedule.
# Uses the same hour syntax as SYNC_SCHEDULE_HOURS.
# Requires RSS_CONFIG_REMOTE_PATH to be set or the task will be skipped.
RSS_IMPORT_SCHEDULE_ENABLED=false
RSS_IMPORT_SCHEDULE_HOURS=2
