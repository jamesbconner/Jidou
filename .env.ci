# CI environment — safe dummy credentials, no real external services required.
# Copied to .env before docker compose up in the integration job.

# Database
POSTGRES_USER=jidou
POSTGRES_PASSWORD=jidou_ci_password
POSTGRES_DB=jidou
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://jidou:jidou_ci_password@postgres:5432/jidou

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# API
API_PORT=8192
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3100
# No JIDOU_API_KEY — auth disabled so smoke-test curl calls need no header

# TMDB — dummy key; connection test will fail but API startup will succeed
TMDB_API_KEY=ci_dummy_tmdb_key
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_RATE_LIMIT_PER_SECOND=0.5
TMDB_CACHE_TTL=86400

# LLM — disabled
LLM_PROVIDER=none
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_CACHE_TTL=3600
LLM_TIMEOUT=30

# SFTP — not configured
SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
SFTP_PASSWORD=
SFTP_KEY_FILE=
SFTP_KEY_PATH=
SFTP_REMOTE_PATHS=/
SFTP_MAX_WORKERS=4
SFTP_MAX_RETRIES=3
SFTP_RETRY_DELAY=1.0

# Media paths — use in-container scratch paths; no real files needed
LOCAL_STAGING_HOST_PATH=/tmp/jidou-ci/staging
LOCAL_STAGING_PATH=/tmp/jidou-ci/staging
LOCAL_TV_HOST_PATH=/tmp/jidou-ci/tv
LOCAL_TV_PATH=/tmp/jidou-ci/tv
LOCAL_ANIME_HOST_PATH=/tmp/jidou-ci/anime
LOCAL_ANIME_PATH=/tmp/jidou-ci/anime
LOCAL_MOVIE_HOST_PATH=/tmp/jidou-ci/movies
LOCAL_MOVIE_PATH=/tmp/jidou-ci/movies

# Frontend
FRONTEND_PORT=3100

# Celery
CELERY_CONCURRENCY=2
CELERY_PREFETCH_MULTIPLIER=1
